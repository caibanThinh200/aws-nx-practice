# Environment Variables Template

# Copy this file to .env.local and fill in your values

# API Base URL (for production deployments)
# Leave empty for local development (uses Vite proxy)
VITE_API_URL=

# AWS Configuration (for local development with real AWS resources)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB Table Name (if connecting to real DynamoDB locally)
# ITEMS_TABLE=org-api-items-dev
